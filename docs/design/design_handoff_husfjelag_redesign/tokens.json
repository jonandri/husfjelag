{
  "$description": "Husfjelag design tokens. Source of truth: ds/colors_and_type.css. Use these in your codebase's design-token system (CSS vars, Tailwind config, theme.ts, etc.).",
  "color": {
    "brand": {
      "navy":        "#1D366F",
      "navyHover":   "#162D5E",
      "navyTint":    "#EEF1F8",
      "navyTint2":   "#C5CFE8",
      "navyDeep":    "#0D2154",
      "green":       "#08C076",
      "greenHover":  "#06A866",
      "greenTint":   "#E8F5E9"
    },
    "neutral": {
      "white":       "#FFFFFF",
      "bgPage":      "#FFFFFF",
      "bgToolbar":   "#FAFAFA",
      "bgTableHead": "#F5F5F5",
      "bgSoft":      "#F3F4F6",
      "bgSection":   "#FAFAFA",
      "border":      "#E8E8E8",
      "borderRow":   "#F2F2F2"
    },
    "text": {
      "primary":   "#111111",
      "body":      "#333333",
      "secondary": "#555555",
      "tertiary":  "#777777",
      "disabled":  "#888888",
      "faint":     "#AAAAAA"
    },
    "semantic": {
      "positive":      "#2E7D32",
      "negative":      "#C62828",
      "negativeHover": "#8B0000",
      "warning":       "#E65100",
      "info":          "#1565C0"
    },
    "chip": {
      "paid":       { "bg": "#E8F5E9", "fg": "#2E7D32" },
      "unpaid":     { "bg": "#FFF3E0", "fg": "#E65100" },
      "label":      { "bg": "#E8F5E9", "fg": "#2E7D32" },
      "labelNavy":  { "bg": "#E3E8F4", "fg": "#1D366F" },
      "imported":   { "bg": "#FFF8E1", "fg": "#E65100" },
      "reconciled": { "bg": "#E8F4FD", "fg": "#1565C0" },
      "categorised":{ "bg": "#F3F4F6", "fg": "#555555" }
    }
  },
  "font": {
    "sans": "Switzer, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace",
    "feature": "tnum"
  },
  "fontSize": {
    "11": "0.6875rem",
    "12": "0.75rem",
    "13": "0.8125rem",
    "14": "0.875rem",
    "16": "1rem",
    "18": "1.125rem",
    "20": "1.25rem",
    "24": "1.5rem",
    "32": "2rem",
    "42": "2.625rem"
  },
  "fontWeight": {
    "thin": 200, "regular": 400, "medium": 500, "semi": 600, "bold": 700
  },
  "lineHeight": { "tight": 1.25, "base": 1.55, "loose": 1.75 },
  "tracking": { "wide": "0.06em", "eyebrow": "0.10em", "table": "0.06em" },
  "spacing": {
    "0": "0px", "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px"
  },
  "radius": {
    "1": "4px", "2": "8px", "3": "12px",
    "pill": "20px", "pillLg": "24px", "circle": "50%"
  },
  "borderWidth": { "1": "1px", "15": "1.5px", "2": "2px" },
  "shadow": {
    "cta":   "0 2px 12px rgba(0,0,0,0.20)",
    "card":  "0 1px 2px rgba(17,17,17,0.04), 0 2px 6px rgba(17,17,17,0.04)",
    "pop":   "0 8px 24px rgba(17,17,17,0.10)",
    "modal": "0 12px 40px rgba(13,33,84,0.18)"
  },
  "motion": {
    "ease": "cubic-bezier(0.2, 0, 0, 1)",
    "durFast": "0.15s",
    "durBase": "0.20s"
  }
}
