#DJANGO
DJANGO_ENV=development
DJANGO_DEBUG=True
SECRET_KEY=             # change-me-generate-with-python-m-secrets-token-hex-50

#HOSTS and CORS
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3003

# Frontend URL (used after login to redirect back to the app)
FRONTEND_URL=http://localhost:3003

#DATABASE
DATABASE_URL=           # local: postgresql://localhost:5432/husfjelag_dev
                        # prod: DO managed binding

#Redis cache
REDIS_URL=redis://localhost:6379/0

# Húsfjelag OIDC (id.husfjelag.is) — get the client secret from the IdP
OIDC_CLIENT_ID=husfjelag-web
OIDC_CLIENT_SECRET=     # husfjelag-web client secret from id.husfjelag.is
OIDC_REDIRECT_URI=http://localhost:8010/auth/callback

# BugSnag error tracking
BUGSNAG_API_KEY=        # no need to connect bugsnag to dev environment

# Email — Resend (event reminder emails). Leave RESEND_API_KEY empty in dev to
# log instead of sending. Prod requires a verified sending domain.
RESEND_API_KEY=         # API key from resend.com
DEFAULT_FROM_EMAIL=Húsfélag <noreply@husfjelag.is>

# Skattur Cloud — Icelandic company registry API
SKATTUR_CLOUD_API_KEY=  # API key from skattur / RSK for Fyrirtækjaskrá / Húsfélag lookup

# Já / Gagnatorg — national person registry (name lookup by kennitala)
# Docs: https://gagnatorg.ja.is/docs/skra/v1/#
JA_API_KEY=             # API key from ja.is / Gagnatorg for Þjóðskrá lookup

# Bank integration
# Generate Fernet key: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BANK_FERNET_KEY=        # YourFernetKeyGoesHere
BANK_LANDSBANKINN_AUTH_URL=https://mtls-auth.landsbankinn.is/connect/token
BANK_LANDSBANKINN_API_BASE=https://apisandbox.landsbankinn.is/api
BANK_LANDSBANKINN_EMAIL=  # Email address to notify when using BANK_SERVICE claim mode
# Íslandsbanki (SOAP). Single host for WSDL + .asmx endpoints. Signing reuses BUNADARSKILRIKI.
BANK_ISLANDSBANKI_BASE=https://ws-test.isb.is/adgerdirv1/   # PROD: https://ws.isb.is/adgerdirv1/
BANK_ISLANDSBANKI_EMAIL=  # húsfélagaþjónusta inbox for BANK_SERVICE budget email (PROD: husfelag@islandsbanki.is)

# Landsbankinn mTLS certificate — managed by Doppler, injected at runtime.
# Do NOT put real values here. Run 'doppler setup' then 'doppler run -- <cmd>'.
# To encode a PFX: base64 -i company.p12 | tr -d '\n'
BUNADARSKILRIKI=        # base64-encoded PFX, sjá Doppler
BUNADARSKILRIKI_PWD=    # PFX password, sjá Doppler