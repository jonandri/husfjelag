DJANGO_ENV=development
DJANGO_DEBUG=True
SECRET_KEY=change-me-generate-with-python-m-secrets-token-hex-50
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://husfelag:password@localhost:5432/husfelag
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:3003

# Kenni OIDC — get client secret from your Kenni dashboard
KENNI_CLIENT_ID=@digit.is/husfjelag
KENNI_CLIENT_SECRET=your-kenni-client-secret
KENNI_REDIRECT_URI=http://localhost:8003/auth/callback

# Frontend URL (used after login to redirect back to the app)
FRONTEND_URL=http://localhost:3003

# Bank integration
# Generate key with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BANK_FERNET_KEY=
BANK_LANDSBANKINN_ENABLED=false
BANK_LANDSBANKINN_CLIENT_ID=
BANK_LANDSBANKINN_CLIENT_SECRET=
BANK_LANDSBANKINN_REDIRECT_URI=http://localhost:8000/bank/callback/landsbankinn
BANK_LANDSBANKINN_API_BASE=https://psd2.landsbanki.is/sandbox/v1
BANK_LANDSBANKINN_AUTH_URL=https://psd2.landsbanki.is/sandbox/oauth2/auth
BANK_LANDSBANKINN_TOKEN_URL=https://psd2.landsbanki.is/sandbox/oauth2/token
